generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───

enum Role {
  CUSTOMER
  SELLER
  ADMIN
  BUSINESS
}

/// Role within an organization (B2B buyer app). Distinct from platform `Role`.
enum OrganizationMemberRole {
  ORG_ADMIN
  BUYER
  APPROVER
}

enum OrderStatus {
  PENDING
  PROCESSING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum AddressType {
  HOME
  OFFICE
  OTHER
}

enum ProductStatus {
  ACTIVE
  ON_HOLD
  PENDING
  DRAFT
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum SellerOnboardingStatus {
  PENDING_VERIFICATION
  EMAIL_VERIFIED
  PHONE_VERIFIED
  DOCUMENTS_SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum DocumentType {
  PAN_CARD
  MASKED_AADHAAR
  GST_CERTIFICATE
  CANCELLED_CHEQUE
  BUSINESS_LICENSE
  ADDRESS_PROOF
  IDENTITY_PROOF
  SIGNATURE
}

enum AuthProvider {
  EMAIL
  PHONE
  GOOGLE
}

enum ShippingMode {
  SELF_SHIP
  XELNOVA_COURIER
  DELHIVERY
  SHIPROCKET
  XPRESSBEES
  EKART
}

enum ShipmentStatus {
  PENDING
  BOOKED
  PICKUP_SCHEDULED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RTO_INITIATED
  RTO_DELIVERED
  CANCELLED
}

// ─── User & Auth ───

model User {
  id                String       @id @default(cuid())
  name              String
  email             String?      @unique
  phone             String?      @unique
  password          String
  avatar            String?
  role              Role         @default(CUSTOMER)
  authProvider      AuthProvider @default(EMAIL)
  emailVerified     Boolean      @default(false)
  phoneVerified     Boolean      @default(false)
  lastLoginAt       DateTime?
  lastLoginIp       String?
  lastLoginLocation Json?
  loginCount        Int          @default(0)
  isActive          Boolean      @default(true)
  isBanned          Boolean      @default(false)
  banReason         String?
  /**
   * Optional link to a custom admin RBAC role (used for sub-admins). When
   * `role = ADMIN` and `adminRoleId` is set, the user has the permissions
   * granted by that AdminRole. The classic super-admin keeps `adminRoleId`
   * null and has unrestricted access.
   */
  adminRoleId       String?
  adminRole         AdminRole?   @relation("AdminRoleUsers", fields: [adminRoleId], references: [id], onDelete: SetNull)

  // Aadhaar verification for wallet access
  aadhaarVerified     Boolean   @default(false)
  aadhaarVerifiedAt   DateTime?
  aadhaarVerifiedData Json?

  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  addresses        Address[]
  orders           Order[]
  reviews          Review[]
  cartItems        CartItem[]
  wishlist         Wishlist[]
  refreshTokens    RefreshToken[]
  sellerProfile    SellerProfile?
  sessions         UserSession[]
  activityLogs     ActivityLog[]
  verificationLogs VerificationLog[]
  returnRequests   ReturnRequest[]
  tickets          Ticket[]
  ticketMessages   TicketMessage[]
  organizationMembers OrganizationMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// ─── B2B Organizations (business buyer accounts) ───

model Organization {
  id        String   @id @default(cuid())
  name      String
  legalName String?
  /// India GSTIN (15 chars) when applicable
  gstin     String?

  members OrganizationMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("organizations")
}

model OrganizationMember {
  id             String                   @id @default(cuid())
  userId         String
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role           OrganizationMemberRole   @default(BUYER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@map("organization_members")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ─── Address ───

model Address {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  district     String?
  state        String
  pincode      String
  landmark     String?
  type         AddressType @default(HOME)
  isDefault    Boolean     @default(false)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("addresses")
}

// ─── Seller ───

model SellerProfile {
  id          String  @id @default(cuid())
  userId      String? @unique
  user        User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  email       String? @unique
  phone       String?
  storeName   String
  slug        String  @unique
  /**
   * Public-facing seller code, e.g. `Grand_HR-XEL00001`. Generated on
   * approval and used as the seller's friendly ID on the storefront and in
   * dashboards. Optional because legacy sellers are backfilled lazily.
   */
  sellerCode  String? @unique
  /** Sequential number used when composing sellerCode. */
  sellerCodeSequence Int? @unique
  logo        String?
  description String?
  verified    Boolean @default(false)
  location    String?
  rating      Float   @default(0)
  totalSales  Int     @default(0)

  // Onboarding status
  onboardingStatus      SellerOnboardingStatus @default(PENDING_VERIFICATION)
  onboardingStep        Int                    @default(1)
  onboardingCompletedAt DateTime?
  rejectionReason       String?
  reviewedBy            String?
  reviewedAt            DateTime?

  // GST Details
  gstNumber           String?
  gstVerified         Boolean   @default(false)
  gstVerifiedAt       DateTime?
  gstVerifiedData     Json?
  gstCertificateUrl   String?
  sellsNonGstProducts Boolean   @default(false)

  // PAN Details
  panNumber        String?
  panName          String?
  panVerified      Boolean   @default(false)
  panVerifiedAt    DateTime?
  panVerifiedData  Json?
  panDocumentUrl   String?
  maskedAadhaarUrl String?

  // Aadhaar Details
  aadhaarNumber       String?
  aadhaarVerified     Boolean   @default(false)
  aadhaarVerifiedAt   DateTime?
  aadhaarVerifiedData Json?

  // Signature
  signatureUrl           String?
  signatureData          String?   @db.Text
  signatureVerified      Boolean   @default(false)
  signatureVerifiedAt    DateTime?
  signatureVerifiedBy    String?
  signatureRejectionNote String?

  // Category Selection
  categorySelectionType String?
  selectedCategories    String[]

  // Bank Details
  bankAccountName    String?
  bankAccountNumber  String?
  bankIfscCode       String?
  bankVerified       Boolean   @default(false)
  bankVerifiedAt     DateTime?
  bankVerifiedData   Json?
  bankVerifiedName   String?
  bankName           String?
  bankBranch         String?
  cancelledChequeUrl String?

  commissionRate Float @default(10)

  // Business Address (Pickup Address)
  businessAddress  String?
  businessCity     String?
  businessState    String?
  businessPincode  String?
  businessType     String?
  businessCategory String?

  // Shipping Preferences
  shippingMethod          String? @default("easy_ship")
  offerFreeDelivery       Boolean @default(true)
  deliveryCharge1to3Days  Float?
  deliveryCharge3PlusDays Float?

  // Store Customization (Brand Store)
  heroBannerUrl      String?
  heroBannerMobile   String?
  aboutTitle         String?
  aboutDescription   String?  @db.Text
  featuredProductIds String[]
  storeThemeColor    String?  @default("#7c3aed")

  products       Product[]
  payouts        Payout[]
  documents      SellerDocument[]
  courierConfigs SellerCourierConfig[]
  shipments      Shipment[]
  storeBanners   SellerStoreBanner[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("seller_profiles")
}

// Seller Store Banners (for brand store carousel)
model SellerStoreBanner {
  id        String        @id @default(cuid())
  sellerId  String
  seller    SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  title     String?
  imageUrl  String
  mobileUrl String?
  link      String?
  sortOrder Int           @default(0)
  isActive  Boolean       @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@map("seller_store_banners")
}

// Seller Documents for verification
model SellerDocument {
  id            String        @id @default(cuid())
  sellerId      String
  seller        SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  type          DocumentType
  fileName      String
  fileUrl       String
  fileSize      Int?
  mimeType      String?
  verified      Boolean       @default(false)
  verifiedAt    DateTime?
  verifiedBy    String?
  rejectionNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([type])
  @@map("seller_documents")
}

// OTP Verification
model OtpVerification {
  id          String    @id @default(cuid())
  identifier  String // email or phone
  type        String // EMAIL or PHONE
  otp         String
  purpose     String // REGISTRATION, LOGIN, PASSWORD_RESET
  expiresAt   DateTime
  verified    Boolean   @default(false)
  verifiedAt  DateTime?
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  userId      String?
  ipAddress   String?

  createdAt DateTime @default(now())

  @@index([identifier, type])
  @@index([otp])
  @@map("otp_verifications")
}

// Puzzle CAPTCHA Sessions
model CaptchaSession {
  id          String    @id @default(cuid())
  sessionId   String    @unique
  puzzleType  String // ROCK_COUNT, IMAGE_MATCH, etc.
  answer      String
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  solved      Boolean   @default(false)
  solvedAt    DateTime?
  expiresAt   DateTime
  ipAddress   String?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@map("captcha_sessions")
}

// ─── Category ───

model Category {
  id           String     @id @default(cuid())
  name         String
  slug         String     @unique
  description  String?
  image        String?
  parentId     String?
  parent       Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[] @relation("CategoryTree")
  productCount Int        @default(0)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@map("categories")
}

// ─── Product ───

model Product {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  shortDescription String?
  description      String?
  price            Float
  compareAtPrice   Float?
  images           String[]

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  brand      String?

  sellerId String
  seller   SellerProfile @relation(fields: [sellerId], references: [id])

  rating      Float @default(0)
  reviewCount Int   @default(0)
  stock       Int   @default(0)

  isFeatured      Boolean   @default(false)
  isTrending      Boolean   @default(false)
  isFlashDeal     Boolean   @default(false)
  flashDealEndsAt DateTime?

  variants       Json?
  specifications Json?
  highlights     String[]
  tags           String[]

  // Amazon-style product information sections
  featuresAndSpecs   Json? // { "Light Source Type": "LED", "Power Source": "Battery", ... }
  materialsAndCare   Json? // { "Material": "Plastic", "Care Instructions": "Wipe clean", ... }
  itemDetails        Json? // { "Manufacturer": "XYZ Corp", "Country of Origin": "India", ... }
  additionalDetails  Json? // { "ASIN": "B0XXX", "Best Sellers Rank": "#1 in Toys", ... }
  productDescription String? @db.Text // Detailed long-form product description
  safetyInfo         String? @db.Text // Safety and product resources information
  regulatoryInfo     String? @db.Text // BIS marking, certifications, etc.
  warrantyInfo       String? // e.g., "1 Year Manufacturer Warranty"
  deliveredBy        String? @default("Xelnova") // "Xelnova Delivered" or seller name

  isActive        Boolean       @default(false)
  status          ProductStatus @default(PENDING)
  rejectionReason String?
  sku             String?

  metaTitle         String?
  metaDescription   String?
  hsnCode           String?
  gstRate           Float?
  /**
   * Commission percentage charged for this listing. Set by the admin when
   * the product is approved; falls back to the seller's default
   * commissionRate when null at order time.
   */
  commissionRate    Float?
  lowStockThreshold Int     @default(5)
  /**
   * Curated bestseller rank assigned by the admin (lower = higher priority).
   * Sellers cannot set this themselves — it's used to power the
   * "Best Sellers" merchandising rails.
   */
  bestSellersRank   Int?

  // Shipping details
  weight     Float? // Weight in kg
  dimensions String? // Format: LxWxH in cm (e.g., "30x20x15")

  // Return/Cancellation/Replacement policies
  isCancellable      Boolean @default(true) // Can be cancelled before shipping
  isReturnable       Boolean @default(true) // Can be returned after delivery
  isReplaceable      Boolean @default(false) // Can be replaced (exchange)
  returnWindow       Int     @default(7) // Return window in days after delivery
  cancellationWindow Int     @default(0) // Hours after order placement (0 = until shipped)

  reviews    Review[]
  orderItems OrderItem[]
  cartItems  CartItem[]
  wishlist   Wishlist[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([sellerId])
  @@index([isFeatured])
  @@index([isTrending])
  @@index([isFlashDeal])
  @@index([status])
  @@map("products")
}

// ─── Review ───

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  title     String?
  comment   String?
  images    String[]
  verified  Boolean  @default(false)
  approved  Boolean  @default(false)
  helpful   Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([userId])
  @@index([approved])
  @@map("reviews")
}

// ─── Order ───

model Order {
  id          String @id @default(cuid())
  orderNumber String @unique
  userId      String
  user        User   @relation(fields: [userId], references: [id])

  items OrderItem[]

  subtotal Float
  discount Float @default(0)
  shipping Float @default(0)
  tax      Float @default(0)
  total    Float

  status        OrderStatus @default(PENDING)
  paymentMethod String?

  shippingAddressId String?
  shippingAddress   Address? @relation(fields: [shippingAddressId], references: [id])

  couponCode        String?
  estimatedDelivery DateTime?

  paymentId     String?
  paymentStatus PaymentStatus @default(PENDING)

  shipment       Shipment?
  returnRequests ReturnRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  product      Product @relation(fields: [productId], references: [id])
  productName  String
  productImage String?
  quantity     Int
  price        Float
  variant      String?
  // Tax/Invoice fields
  hsnCode      String?
  gstRate      Float?  @default(18)
  imeiSerialNo String? // For electronics IMEI/Serial numbers
  sellerId     String? // Seller who fulfilled this item

  @@index([orderId])
  @@map("order_items")
}

// ─── Return / Refund ───

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  PICKED_UP
  REFUNDED
}

model ReturnRequest {
  id           String       @id @default(cuid())
  orderId      String
  order        Order        @relation(fields: [orderId], references: [id])
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  reason       String
  status       ReturnStatus @default(REQUESTED)
  adminNote    String?
  refundAmount Float?

  reverseAwb             String?
  reverseCourier         String?
  reverseTrackingUrl     String?
  reversePickupScheduled DateTime?
  reversePickedUpAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([userId])
  @@map("return_requests")
}

// ─── Cart ───

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)
  variant   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, variant])
  @@map("cart_items")
}

// ─── Wishlist ───

model Wishlist {
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, productId])
  @@map("wishlists")
}

// ─── Coupon ───

model Coupon {
  id             String       @id @default(cuid())
  code           String       @unique
  description    String?
  discountType   DiscountType
  discountValue  Float
  minOrderAmount Float        @default(0)
  maxDiscount    Float?
  validUntil     DateTime?
  isActive       Boolean      @default(true)
  usageLimit     Int?
  usedCount      Int          @default(0)

  scope      String  @default("global")
  categoryId String?
  sellerId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("coupons")
}

// ─── Banner ───

model Banner {
  id          String    @id @default(cuid())
  title       String
  subtitle    String?
  description String?
  image       String?
  ctaText     String?
  ctaLink     String?
  bgColor     String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  position    String    @default("hero")
  clicks      Int       @default(0)
  impressions Int       @default(0)
  startDate   DateTime?
  endDate     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

// ─── Brand ───

model Brand {
  id       String  @id @default(cuid())
  name     String  @unique
  slug     String  @unique
  logo     String?
  featured Boolean @default(false)
  isActive Boolean @default(true)

  proposedBy String?
  approved   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("brands")
}

// ─── Payout ───

model Payout {
  id       String        @id @default(cuid())
  sellerId String
  seller   SellerProfile @relation(fields: [sellerId], references: [id])
  amount   Float
  status   PayoutStatus  @default(PENDING)
  method   String        @default("bank_transfer")
  note     String?

  razorpayTransferId String?
  isAdvance          Boolean @default(false)
  orderId            String?

  requestedAt DateTime  @default(now())
  paidAt      DateTime?

  @@index([sellerId])
  @@index([status])
  @@map("payouts")
}

// ─── Commission Rule ───

model CommissionRule {
  id           String  @id @default(cuid())
  categorySlug String
  rate         Float
  isPercentage Boolean @default(true)
  minOrder     Float   @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("commission_rules")
}

// ─── CMS Page ───

model CmsPage {
  id      String  @id @default(cuid())
  title   String
  slug    String  @unique
  content String?
  status  String  @default("draft")
  author  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cms_pages")
}

// ─── Activity Log ───

model ActivityLog {
  id        String  @id @default(cuid())
  type      String
  action    String
  message   String
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  userRole  Role?
  ipAddress String?
  userAgent String?
  location  Json?
  meta      Json?
  duration  Int?
  status    String  @default("success")
  endpoint  String?
  method    String?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── User Session ───

model UserSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token        String   @unique
  ipAddress    String?
  userAgent    String?
  device       String?
  browser      String?
  os           String?
  location     Json?
  city         String?
  region       String?
  country      String?
  latitude     Float?
  longitude    Float?
  isActive     Boolean  @default(true)
  lastActivity DateTime @default(now())
  expiresAt    DateTime

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([isActive])
  @@map("user_sessions")
}

// ─── API Request Log ───

model ApiRequestLog {
  id           String  @id @default(cuid())
  method       String
  endpoint     String
  statusCode   Int
  responseTime Int
  userId       String?
  ipAddress    String?
  userAgent    String?
  requestBody  Json?
  responseBody Json?
  error        String?
  location     Json?

  createdAt DateTime @default(now())

  @@index([endpoint])
  @@index([userId])
  @@index([statusCode])
  @@index([createdAt])
  @@map("api_request_logs")
}

// ─── Admin Role (custom roles for RBAC) ───

model AdminRole {
  id          String  @id @default(cuid())
  name        String  @unique
  /**
   * Comma-separated list of permission tokens (e.g. "products,orders,reviews")
   * understood by the backend RBAC guard and the admin UI.
   */
  permissions String
  isSystem    Boolean @default(false)

  /// Sub-admin users assigned to this role.
  members     User[]  @relation("AdminRoleUsers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admin_roles")
}

// ─── System Performance Log ───

model PerformanceLog {
  id            String  @id @default(cuid())
  type          String
  metric        String
  value         Float
  unit          String
  endpoint      String?
  memoryUsage   Float?
  cpuUsage      Float?
  activeUsers   Int?
  requestCount  Int?
  errorCount    Int?
  avgResponseMs Float?
  meta          Json?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([metric])
  @@index([createdAt])
  @@map("performance_logs")
}

// ─── Verification Log ───

model VerificationLog {
  id           String  @id @default(cuid())
  type         String
  identifier   String
  status       String
  response     Json?
  userId       String?
  user         User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  verifiedData Json?
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([type])
  @@index([identifier])
  @@index([userId])
  @@map("verification_logs")
}

// ─── Shipment ───

model Shipment {
  id       String        @id @default(cuid())
  orderId  String        @unique
  order    Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sellerId String
  seller   SellerProfile @relation(fields: [sellerId], references: [id])

  shippingMode    ShippingMode
  courierProvider String?
  awbNumber       String?
  trackingUrl     String?
  shipmentStatus  ShipmentStatus @default(PENDING)
  courierOrderId  String?
  labelUrl        String?
  manifestUrl     String?
  pickupDate      DateTime?
  deliveredAt     DateTime?
  weight          Float?
  dimensions      String?
  courierCharges  Float?
  statusHistory   Json           @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([awbNumber])
  @@index([shipmentStatus])
  @@map("shipments")
}

// ─── Seller Courier Config ───

model SellerCourierConfig {
  id          String        @id @default(cuid())
  sellerId    String
  seller      SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  provider    ShippingMode
  apiKey      String
  apiSecret   String?
  accountId   String?
  isActive    Boolean       @default(true)
  warehouseId String?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sellerId, provider])
  @@index([sellerId])
  @@map("seller_courier_configs")
}

// ─── Wallet ───

enum WalletOwnerType {
  ADMIN
  SELLER
  CUSTOMER
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum WalletReferenceType {
  PAYOUT
  SHIPPING_PAYMENT
  COMMISSION
  MANUAL
  REFUND
  WALLET_TOPUP
  TRANSFER
  RECHARGE
  BILL_PAYMENT
}

enum BankTransferStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Wallet {
  id        String          @id @default(cuid())
  ownerId   String
  ownerType WalletOwnerType
  balance   Float           @default(0)

  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerId, ownerType])
  @@index([ownerId])
  @@map("wallets")
}

model WalletTransaction {
  id            String                @id @default(cuid())
  walletId      String
  wallet        Wallet                @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          WalletTransactionType
  amount        Float
  balanceAfter  Float
  description   String
  referenceType WalletReferenceType   @default(MANUAL)
  referenceId   String?
  createdBy     String?

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([referenceType])
  @@map("wallet_transactions")
}

model BankTransferRequest {
  id             String             @id @default(cuid())
  walletId       String
  userId         String
  amount         Float
  accountNumber  String
  ifscCode       String
  accountHolder  String
  status         BankTransferStatus @default(PENDING)
  transactionRef String?
  failureReason  String?
  processedAt    DateTime?
  processedBy    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([walletId])
  @@index([userId])
  @@index([status])
  @@map("bank_transfer_requests")
}

// ─── Site-wide admin settings (singleton row id = 1) ───

model SiteSettings {
  id        Int      @id @default(1)
  payload   Json
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─── Support Tickets ───

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id           String         @id @default(cuid())
  ticketNumber String         @unique
  subject      String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)

  customerId       String
  customer         User    @relation(fields: [customerId], references: [id])
  orderId          String?
  assignedSellerId String?
  assignedAdminId  String?

  messages TicketMessage[]

  closedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([customerId])
  @@index([assignedSellerId])
  @@index([status])
  @@map("tickets")
}

model TicketMessage {
  id          String  @id @default(cuid())
  ticketId    String
  ticket      Ticket  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User    @relation(fields: [senderId], references: [id])
  senderRole  String
  message     String
  isInternal  Boolean @default(false)
  isForwarded Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([ticketId])
  @@map("ticket_messages")
}

// ─── Abandoned Cart Reminders ───

model AbandonedCartReminder {
  id        String   @id @default(cuid())
  userId    String
  email     String
  cartValue Float
  itemCount Int
  sentAt    DateTime @default(now())
  channel   String   @default("email")
  converted Boolean  @default(false)

  @@index([userId])
  @@index([sentAt])
  @@map("abandoned_cart_reminders")
}

// ─── Loyalty & Referral ───

model LoyaltyLedger {
  id          String    @id @default(cuid())
  userId      String
  points      Int
  type        String
  description String
  referenceId String?
  expiresAt   DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("loyalty_ledger")
}

model ReferralCode {
  id           String  @id @default(cuid())
  userId       String  @unique
  code         String  @unique
  totalUses    Int     @default(0)
  earnedPoints Int     @default(0)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("referral_codes")
}

model ReferralUse {
  id             String  @id @default(cuid())
  referralCodeId String
  referredUserId String
  orderId        String?
  pointsAwarded  Int     @default(0)

  createdAt DateTime @default(now())

  @@index([referralCodeId])
  @@index([referredUserId])
  @@map("referral_uses")
}

// ─── Fraud Detection ───

enum FraudFlagStatus {
  PENDING
  REVIEWED
  CLEARED
  BLOCKED
}

model FraudFlag {
  id         String          @id @default(cuid())
  orderId    String
  userId     String
  rules      String[]
  riskScore  Int             @default(0)
  status     FraudFlagStatus @default(PENDING)
  adminNote  String?
  reviewedBy String?
  reviewedAt DateTime?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("fraud_flags")
}

// ─── Push Notification Tokens ───

model PushToken {
  id       String  @id @default(cuid())
  userId   String
  token    String
  platform String  @default("web")
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
  @@index([userId])
  @@map("push_tokens")
}

// ─── Notification Log ───

model NotificationLog {
  id      String    @id @default(cuid())
  userId  String
  channel String
  type    String
  title   String
  body    String
  data    Json?
  sent    Boolean   @default(true)
  read    Boolean   @default(false)
  readAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([channel])
  @@index([createdAt])
  @@map("notification_logs")
}

// ─── Feature Flags ───

model FeatureFlag {
  id          String  @id @default(cuid())
  key         String  @unique
  name        String
  description String?
  enabled     Boolean @default(false)
  percentage  Int     @default(100)
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@map("feature_flags")
}
