# Production environment — copy to .env.production and fill in real values
# This file is used by docker-compose.yml (env_file: ./backend/.env.production)

NODE_ENV=production

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@your-neon-host.neon.tech/xelnova?sslmode=require"

# JWT — generate strong random secrets (64+ chars each)
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="https://api.xelnova.com/api/v1/auth/google/callback"

# Frontend URLs (production domains)
FRONTEND_URL="https://xelnova.com"
SELLER_URL="https://seller.xelnova.com"
ADMIN_URL="https://admin.xelnova.com"
APP_URL="https://xelnova.com"

# Server
PORT=4000
CORS_ORIGINS="https://xelnova.com,https://www.xelnova.com,https://seller.xelnova.com,https://admin.xelnova.com"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Xelnova <noreply@xelnova.com>"

# SMS (Fortius)
FORTIUS_API_KEY=""
FORTIUS_SENDER_ID="XELN"
FORTIUS_OTP_TEMPLATE_ID=""

# Google reCAPTCHA v2
RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# GSTIN Verification
GSTIN_API_KEY=""

# eKYC Hub (Penny Drop)
EKYCHUB_USERNAME=""
EKYCHUB_TOKEN=""
