# Production environment — copy to .env on the server and fill in real values.
# On EC2: ~/backend/.env

NODE_ENV=production

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@your-neon-host.neon.tech/xelnova?sslmode=require"

# JWT — generate strong random secrets (64+ chars each)
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="https://api.xelnova.in/api/v1/auth/google/callback"

# Frontend URLs (production domains)
FRONTEND_URL="https://xelnova.in"
SELLER_URL="https://seller.xelnova.in"
ADMIN_URL="https://admin.xelnova.in"
APP_URL="https://xelnova.in"

# Server
PORT=4000
CORS_ORIGINS="https://xelnova.in,https://www.xelnova.in,https://seller.xelnova.in,https://admin.xelnova.in"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_URL=""

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Email (Resend) — required in production for OTP
RESEND_API_KEY=""
EMAIL_FROM="Xelnova <noreply@xelnova.in>"

# SMS (Fortius) — required in production for phone OTP
FORTIUS_API_KEY=""
FORTIUS_SENDER_ID="XELN"
FORTIUS_OTP_TEMPLATE_ID=""
FORTIUS_OTP_MESSAGE="XELNOVA: Your OTP is {#var#}. Please do not share this code with anyone. It is valid for 10 minutes."

# Google reCAPTCHA Enterprise
# Site key from https://console.cloud.google.com/security/recaptcha
# API key from https://console.cloud.google.com/apis/credentials
RECAPTCHA_SITE_KEY=""
RECAPTCHA_PROJECT_ID=""
RECAPTCHA_API_KEY=""

# GSTIN Verification
GSTIN_API_KEY=""

# eKYC Hub (Bank verification + Digilocker Aadhaar/PAN + PAN 360)
# Get credentials from https://ekychub.in
EKYCHUB_USERNAME=""
EKYCHUB_TOKEN=""
# URL where user is redirected after Digilocker verification (seller app origin + callback path)
# After Digilocker verification, user is redirected to this backend endpoint.
# It serves a small HTML page that auto-closes the popup window.
EKYCHUB_DIGILOCKER_REDIRECT_URL="https://api.xelnova.in/api/v1/verification/digilocker/callback"
