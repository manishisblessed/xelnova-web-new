{
  "name": "xelnova-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@xelnova/web",
    "dev:api": "turbo run dev --filter=@xelnova/api-app",
    "dev:admin": "turbo run dev --filter=@xelnova/admin",
    "dev:seller": "turbo run dev --filter=@xelnova/seller",
    "dev:backend": "turbo run dev --filter=@xelnova/backend",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
