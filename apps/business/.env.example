# Public URL of this app (optional, for metadata)
NEXT_PUBLIC_BUSINESS_SITE_URL=http://localhost:3004

# API base for client-side calls (defaults to same-origin /api/v1 via Next rewrite)
NEXT_PUBLIC_API_URL=/api/v1

# Consumer storefront link from footer
NEXT_PUBLIC_RETAIL_SITE_URL=https://www.xelnova.in

# Server-side rewrite target (optional; defaults to BACKEND_URL or 127.0.0.1:4000)
# BUSINESS_INTERNAL_API_URL=http://127.0.0.1:4000
