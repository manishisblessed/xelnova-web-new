# ─── Local Development ───
# Browser calls /api/v1 on this Next app; next.config.ts proxies to Nest (default http://127.0.0.1:4000).
# Leave NEXT_PUBLIC_API_URL unset for that behavior. Override proxy target if needed:
# SELLER_INTERNAL_API_URL=http://127.0.0.1:4000
#
# Only set NEXT_PUBLIC_API_URL to an absolute URL if the API is on another host (e.g. production).
# NEXT_PUBLIC_API_URL=https://api.xelnova.in/api/v1

# Google Sign-In (must match GOOGLE_CLIENT_ID in backend/.env; add http://localhost:3003 to OAuth JS origins)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google reCAPTCHA Enterprise — must match RECAPTCHA_SITE_KEY in backend/.env
# Get your site key from https://console.cloud.google.com/security/recaptcha
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# ─── Production ───
# NEXT_PUBLIC_API_URL=https://api.xelnova.in/api/v1
