# NestJS backend (port 4000). Do not point this at the Next.js API app (3001) unless that app proxies /api/v1/seller to the backend.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Google Sign-In (must match the Web client ID in Google Cloud Console and `GOOGLE_CLIENT_ID` in backend/.env)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google reCAPTCHA v2 (checkbox) — must match RECAPTCHA_SITE_KEY in backend/.env
# Default is Google's test key (always passes). Replace for production.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI"
