# ─── Local Development ───
# NestJS backend (port 4000). The backend must be running for OTP, GST, bank verification to work.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Google Sign-In (must match GOOGLE_CLIENT_ID in backend/.env)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google reCAPTCHA Enterprise — must match RECAPTCHA_SITE_KEY in backend/.env
# Get your site key from https://console.cloud.google.com/security/recaptcha
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""

# ─── Production ───
# NEXT_PUBLIC_API_URL=https://api.xelnova.in/api/v1
