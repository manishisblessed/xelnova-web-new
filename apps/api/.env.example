# NestJS backend URL for proxying auth, seller, and verification routes.
# Local dev: set here. Production (Amplify): set NEXT_PUBLIC_BACKEND_URL in the Amplify console
# (next.config.ts maps it to BACKEND_URL at build time).
BACKEND_URL=http://localhost:4000

# GSTIN verification (GET /api/v1/verification/gstin/:gstin) proxies to BACKEND_URL first.
# If the backend is not running, set the same key as backend/.env (optional):
# GSTIN_API_KEY=

# Fortius SMS (used by src/lib/sms-service.ts when seller OTP hits this Next app on port 3001)
# IMPORTANT: All four vars below must match the backend/.env values exactly.
# Without FORTIUS_OTP_TEMPLATE_ID the telecom operator will reject the SMS (DLT non-compliance).
# FORTIUS_API_KEY=
# FORTIUS_SENDER_ID=XELN
# FORTIUS_OTP_TEMPLATE_ID=         # <-- REQUIRED for Indian DLT, get from your DLT portal
# FORTIUS_OTP_MESSAGE="XELNOVA: Your OTP is {#var#}. Please do not share this code with anyone. It is valid for 10 minutes."
